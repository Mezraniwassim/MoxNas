# MoxNAS Environment Configuration Template
# ==========================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control!

# Django Configuration
# --------------------
DEBUG=True
SECRET_KEY=generate-a-secure-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip

# Database Configuration
# ----------------------
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=

# Proxmox Configuration
# --------------------
PROXMOX_HOST=172.16.135.128
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=wc305ekb
PROXMOX_VERIFY_SSL=False
PROXMOX_PORT=8006

# Container Configuration
# -----------------------
CONTAINER_ROOT_PASSWORD=secure-container-root-password
CONTAINER_DEFAULT_PASSWORD=change-this-default-password

# Network Configuration
# ---------------------
NETWORK_INTERFACE=eth0
BRIDGE_INTERFACE=vmbr0

# Storage Configuration
# --------------------
STORAGE_POOL=local-lvm
ISO_STORAGE=local
BACKUP_STORAGE=local

# Security Configuration
# ----------------------
ENCRYPTION_KEY=generate-encryption-key
API_SECRET_KEY=generate-api-secret-key

# Logging Configuration
# --------------------
LOG_LEVEL=INFO
LOG_FILE_PATH=/home/wassim/Documents/MoxNas/backend/logs/moxnas.log

# Service Configuration
# --------------------
SMB_WORKGROUP=WORKGROUP
NFS_EXPORT_OPTIONS=rw,sync,no_subtree_check
FTP_PASSIVE_PORTS=21000-21010
ISCSI_TARGET_PREFIX=iqn.2023-01.com.moxnas

# Email Configuration (for notifications)
# ---------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# Monitoring & Health Check URLs
# ------------------------------
HEALTH_CHECK_URL=http://localhost:8000/health/
MONITORING_ENDPOINT=http://localhost:8000/api/monitoring/
